{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": true,
  "separate-pull-requests": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "FERS",
      "component": "fers",
      "changelog-path": "CHANGELOG.md",
      "version-file": "version.txt",
      "extra-files": [
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vcpkg.json",
          "jsonpath": "$['version-semver']"
        },
        {
          "type": "json",
          "path": "packages/fers-ui/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "packages/fers-ui/src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        }
      ]
    }
  }
}
